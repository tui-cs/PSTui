<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <!-- Canonical source for a community (tui-cs) project. Replaces the
         Microsoft OneBranch CFS mirror, which lagged newer Terminal.Gui
         releases (e.g. 2.4.10 was unavailable there). -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
